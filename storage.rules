rules_version = '2';

// Expense receipt photos live at expenses/{repId}/{file}.
// Mirrors the Firestore model: only signed-in @entouragelab.com users.
// A rep may write/delete only inside their own folder; any entourage user
// may read (managers/admins review receipts). NOTE: when external reps are
// added via an allowlist, this domain check must be revisited (Storage rules
// cannot read Firestore — a custom auth claim is the clean path).
service firebase.storage {
  match /b/{bucket}/o {
    function isEntourageUser() {
      return request.auth != null
          && request.auth.token.email.matches('.*@entouragelab[.]com');
    }

    match /expenses/{repId}/{fileName} {
      allow read: if isEntourageUser();
      allow write: if isEntourageUser()
                   && request.auth.uid == repId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if isEntourageUser() && request.auth.uid == repId;
    }

    // Deny everything else by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
