{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*"
    ],
    "rewrites": [
      {
        "source": "/guia",
        "destination": "/guide/index.html"
      },
      {
        "source": "/guia/",
        "destination": "/guide/index.html"
      },
      {
        "source": "/guide",
        "destination": "/guide/index.html"
      },
      {
        "source": "/guide/",
        "destination": "/guide/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
