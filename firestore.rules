rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    // Must be signed-in with an @entouragelab.com account
    function isEntourageUser() {
      return request.auth != null
          && request.auth.token.email.matches('.*@entouragelab\\.com');
    }

    // Signed-in AND either an entourage account or an admin-approved external
    // user (contractor / marketplace rep on a personal Google account).
    // allowed_users/{email} is keyed by lowercased email — see allowlist below.
    function isMember() {
      return isEntourageUser()
          || (request.auth != null
              && request.auth.token.email != null
              && exists(/databases/$(database)/documents/allowed_users/$(request.auth.token.email.lower()))
              && get(/databases/$(database)/documents/allowed_users/$(request.auth.token.email.lower())).data.active == true);
    }

    // Static super-admin list (mirrors SUPER_ADMIN_EMAILS in provider.tsx)
    // Admin stays entourage-only — promotion is a trusted internal action.
    function isSuperAdmin() {
      return isEntourageUser()
          && request.auth.token.email in [
               'caio@entouragelab.com',
               'mario@entouragelab.com',
               'marcos.freitas@entouragelab.com',
               'tiago.fonseca@entouragelab.com'
             ];
    }

    // Dynamic admin: document must exist in roles_admin
    function isDynamicAdmin() {
      return isEntourageUser()
          && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isAdmin() {
      return isSuperAdmin() || isDynamicAdmin();
    }

    // Manager or admin: gerente role or admin (kept entourage-only, same as admin)
    function isManagerOrAdmin() {
      return isAdmin()
          || (isEntourageUser()
              && get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role in ['gerente', 'admin']);
    }

    // ── allowed_users (external-rep allowlist) ──────────────────────────────────
    // Doc ID is the lowercased email an admin invites. Grants login + read/write
    // access equivalent to an entourage account (see isMember()) without
    // requiring a Workspace account — for one-month-contract reps and
    // marketplace sellers who sign in with a personal Google account.
    // Fields: { email, name, addedBy, addedAt, active }
    match /allowed_users/{email} {
      allow read: if isAdmin()
                  || (request.auth != null
                      && request.auth.token.email != null
                      && request.auth.token.email.lower() == email);
      allow write: if isAdmin();
    }

    // ── doctors ───────────────────────────────────────────────────────────────
    // Any member can read. Admins can write anything.
    // Managers can assign reps to doctors (assignedRepId).
    // Reps can update only the CRM-computed fields (touches, propensity, etc.)
    // Reps can also report a doctor as not found at their address (reported=true only).
    match /doctors/{doctorId} {
      allow read: if isMember();

      allow create: if isAdmin()
                    || (isMember()
                        && request.resource.data.createdByRepId == request.auth.uid);

      allow delete: if isAdmin();

      allow update: if isAdmin()
                    || (isManagerOrAdmin()
                        && request.resource.data.diff(resource.data)
                             .affectedKeys()
                             .hasOnly(['assignedRepId', 'updatedAt']))
                    // Managers can also update tags
                    || (isManagerOrAdmin()
                        && request.resource.data.diff(resource.data)
                             .affectedKeys()
                             .hasOnly(['assignedRepId', 'tags', 'updatedAt']))
                    || (isMember()
                        && request.resource.data.diff(resource.data)
                             .affectedKeys()
                             .hasOnly([
                               'propensityScore',
                               'lastInteractionAt',
                               'lastInteractionResult',
                               'totalTouches',
                               'flaggedForFollowUp',
                               'updatedAt'
                             ]))
                    // Reps can unflag a doctor with a required note
                    || (isMember()
                        && resource.data.flaggedForFollowUp == true
                        && request.resource.data.flaggedForFollowUp == false
                        && request.resource.data.diff(resource.data)
                             .affectedKeys()
                             .hasOnly([
                               'flaggedForFollowUp',
                               'unflaggedBy',
                               'unflaggedAt',
                               'unflagNote',
                               'updatedAt'
                             ]))
                    // Reps can set reported=true (flag as not at address); cannot clear it
                    || (isMember()
                        && request.resource.data.reported == true
                        && request.resource.data.diff(resource.data)
                             .affectedKeys()
                             .hasOnly([
                               'reported',
                               'reportedAt',
                               'reportedBy',
                               'reportedReason',
                               'updatedAt'
                             ]));
    }

    // ── doctor_reports ────────────────────────────────────────────────────────
    // Reps can create reports (doctor-not-at-address).
    // Managers, analysts, and admins can read all reports to follow up.
    // Only admins can update (mark resolved) or delete.
    match /doctor_reports/{reportId} {
      allow create: if isMember()
                    && request.resource.data.repId == request.auth.uid;

      // Managers and admins see all reports. Analysts also see all (for data cleanup).
      // Reps can read only their own reports.
      allow read: if isManagerOrAdmin()
                  || (isEntourageUser()
                      && get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role == 'analista')
                  || (isMember()
                      && resource.data.repId == request.auth.uid);

      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    // ── interactions ─────────────────────────────────────────────────────────
    // Any member can read all interactions. Reps can create their own.
    // Only the owning rep or an admin can update/delete.
    match /interactions/{interactionId} {
      allow read: if isMember();

      allow create: if isMember()
                    && request.resource.data.repId == request.auth.uid
                    && (
                         !('visitDate' in request.resource.data)
                         || request.resource.data.visitDate <= request.time
                       );

      allow update: if isMember()
                   && (resource.data.repId == request.auth.uid || isAdmin())
                   && (
                        !('visitDate' in request.resource.data)
                        || request.resource.data.visitDate <= request.time
                      );

      allow delete: if isMember()
                    && (resource.data.repId == request.auth.uid || isAdmin());
    }

    // ── scheduled_visits ─────────────────────────────────────────────────────
    // Reps can read their own visits. Admins can read/write all.
    // Reps can create their own visits (self-assigned, e.g. from Calendar sync).
    // Reps can update their own visits (e.g. to link googleCalendarEventId).
    match /scheduled_visits/{visitId} {
      allow read: if isMember()
                  && (resource.data.repId == request.auth.uid || isAdmin());

      allow create: if isAdmin()
                    || isManagerOrAdmin()
                    || (isMember()
                        && request.resource.data.repId == request.auth.uid
                        && request.resource.data.assignedBy == request.auth.uid);

      allow update: if isAdmin()
                    || isManagerOrAdmin()
                    || (isMember()
                        && resource.data.repId == request.auth.uid
                        && request.resource.data.repId == resource.data.repId);

      allow delete: if isAdmin();
    }

    // ── weekly_goals ───────────────────────────────────────────────────────────
    // Managers set weekly visit targets for reps.
    match /weekly_goals/{goalId} {
      allow read: if isMember();
      allow write: if isManagerOrAdmin();
    }

    // ── roles ─────────────────────────────────────────────────────────────────
    // Each user can read their own role doc. Admins can read all (for user management).
    // Only admins can assign roles.
    // Fields: { role: 'representante'|'gerente'|'analista'|'admin' }
    match /roles/{userId} {
      allow read: if isMember()
                  && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // ── roles_admin (legacy) ────────────────────────────────────────────────
    // Users can read their own role doc (to check if they're admin).
    // Only super-admins can grant/revoke admin status.
    match /roles_admin/{userId} {
      allow read: if isEntourageUser() && request.auth.uid == userId;
      allow write: if isSuperAdmin();
    }

    // ── representantes ────────────────────────────────────────────────────────
    // Any member can read profiles. Each rep can write only their own
    // (this is also how a user's profile gets created on first login).
    match /representantes/{userId} {
      allow read: if isMember();
      allow write: if isMember() && request.auth.uid == userId;
    }

    // ── expenses ──────────────────────────────────────────────────────────────
    // Reps can create and read their own expenses.
    // Managers and admins can read all expenses (for accounting review).
    // Only the owning rep or admin can update/delete.
    match /expenses/{expenseId} {
      allow create: if isMember()
                    && request.resource.data.repId == request.auth.uid;

      allow read: if isMember()
                  && (resource.data.repId == request.auth.uid || isManagerOrAdmin());

      allow update, delete: if isMember()
                            && (resource.data.repId == request.auth.uid || isAdmin());
    }
  }
}
