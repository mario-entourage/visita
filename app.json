{
  "expo": {
    "name": "VISITA",
    "slug": "visita-crm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "visita",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a3d3d"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.entouragelab.visita",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "VISITA usa sua localização para registrar automaticamente onde ocorreu a interação com o médico.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.471797457785-kmcpfoode8ek4etpa5ibbhucpveu18bo"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a3d3d",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.entouragelab.visita",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "VISITA usa sua localização para registrar automaticamente onde ocorreu a interação com o médico."
        }
      ],
      "expo-web-browser"
    ]
  }
}
